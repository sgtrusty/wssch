{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@config/*": ["./src/config/*"],
      "@runtime/*": ["./src/runtime/*"],
      "@sandbox/*": ["./src/sandbox/*"],
      "@commands/*": ["./src/commands/*"],
      "@lib/*": ["./src/lib/*"],
      "@core/*": ["./src/core/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}