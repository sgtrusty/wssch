# wssafe .env configuration
# Copy to .env in your target project directory

# Ollama (optional - if not available, RAG falls back to non-LLM mode)
OLLAMA_URL=http://192.168.1.50:11434
EMBEDDING_MODEL=lco-embedding-omni-gguf

# Disable features
# NO_RTK=true      # Disable RTK tool
# NO_RAG=true      # Disable RAG (MCP)
# NO_OLLAMA=true    # Disable Ollama (use non-LLM fallback)